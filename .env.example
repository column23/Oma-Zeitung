# Anthropic API Key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Claude-Modell für Zusammenfassungen (Standard: claude-sonnet-5)
ANTHROPIC_MODEL=claude-sonnet-5

# Flask Server
HOST=0.0.0.0
PORT=5000

# Pfad zur SQLite-Datenbank (relativ zum Projekt-Root)
DATABASE_PATH=data/omazeitung.db
