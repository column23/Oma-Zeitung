# Anthropic API Key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Claude-Modell für Zusammenfassungen
#   claude-haiku-4-5  = günstig (Standard)
#   claude-sonnet-5   = höhere Textqualität, ca. doppelte Kosten
ANTHROPIC_MODEL=claude-haiku-4-5

# Flask Server
HOST=0.0.0.0
PORT=5000

# Pfad zur SQLite-Datenbank (relativ zum Projekt-Root)
DATABASE_PATH=data/omazeitung.db
